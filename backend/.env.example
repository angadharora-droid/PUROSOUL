# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/scheme-tracker

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Uploads
UPLOAD_DIR=uploads

# Email (leave blank to disable outgoing mail in development)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Scheme Tracker <no-reply@company.com>"
# Mailbox that receives validation emails (sent from the Validate button)
ACCOUNTS_EMAIL=accounts@company.com
